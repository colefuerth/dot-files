+	float SMCConnection::getSMCFloat(char *key) {
+		SMCVal_t val;
+		kern_return_t result = SMCReadKey(key, &val);
+		if (result == kIOReturnSuccess and val.dataSize == 4 and strcmp(val.dataType, DATATYPE_FLT) == 0) {
+			float value;
+			memcpy(&value, val.bytes, sizeof(value));
+			return value;
+		}
+		return -1.0f;
+	}
+
+	//? Total system power draw. AppleSmartBattery's amperage keys only refresh on the
+	//? battery's slow SMBus poll, so they sit frozen for minutes; the SMC key is live.
+	float SMCConnection::getSystemPower() {
+		char key[] = SMC_KEY_SYSTEM_POWER;
+		return getSMCFloat(key);
+	}
