#!/usr/bin/env bash

# Toggle TV aux-in audio loopback
SERVICE="tv-loopback.service"

case "${1:-}" in
    on|start)
        systemctl --user start "$SERVICE"
        echo "TV audio ON"
        ;;
    off|stop)
        systemctl --user stop "$SERVICE"
        echo "TV audio OFF"
        ;;
    status)
        systemctl --user status "$SERVICE"
        ;;
    *)
        echo "Usage: tv <command>"
        echo ""
        echo "Commands:"
        echo "  on, start   Start TV aux-in audio loopback"
        echo "  off, stop   Stop TV aux-in audio loopback"
        echo "  status      Show loopback service status"
        exit 1
        ;;
esac
